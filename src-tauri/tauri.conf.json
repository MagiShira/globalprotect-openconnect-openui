{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1422",
    "frontendDist": "../dist"
  },
  "identifier": "com.magishira.gpopenui",
  "productName": "GP OpenUI",
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "GP OpenUI",
        "center": true,
        "resizable": false,
        "width": 360,
        "height": 520,
        "minWidth": 360,
        "minHeight": 520,
        "label": "main",
        "decorations": true,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "deb",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
